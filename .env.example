# Copy to .env and fill in. NEVER commit .env.
# .env is gitignored.

# Anthropic API key for the LLM grader.
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend API key for sending the weekly email.
# Get one: https://resend.com/api-keys
RESEND_API_KEY=

# Where the digest gets emailed to.
DIGEST_TO_EMAIL=
